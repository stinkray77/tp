<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:controller="seedu.address.ui.PersonViewDialog" alignment="CENTER" prefWidth="400.0" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Header -->
    <Label fx:id="nameLabel" text="Name">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
    </Label>

    <GridPane hgap="10.0" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints minWidth="80.0" />
            <ColumnConstraints minWidth="250.0" />
        </columnConstraints>

        <rowConstraints>
            <RowConstraints minHeight="25.0" />
            <RowConstraints minHeight="25.0" />
            <RowConstraints minHeight="25.0" />
            <RowConstraints minHeight="25.0" />
            <RowConstraints minHeight="25.0" />
            <RowConstraints minHeight="25.0" />
            <RowConstraints minHeight="25.0" />
            <RowConstraints minHeight="25.0" />
        </rowConstraints>

        <Label text="Emergency Contact:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <Label fx:id="emergencyContactLabel" wrapText="true" GridPane.rowIndex="0" GridPane.columnIndex="1" />

        <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <Label fx:id="emailLabel" wrapText="true" GridPane.rowIndex="1" GridPane.columnIndex="1" />

        <Label text="Address:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <Label fx:id="addressLabel" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="1" />

        <Label text="Tags:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
        <Label fx:id="tagsLabel" wrapText="true" GridPane.rowIndex="3" GridPane.columnIndex="1" />

        <Label text="Payment:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
        <Label fx:id="paymentLabel" wrapText="true" GridPane.rowIndex="4" GridPane.columnIndex="1" />

        <Label text="Subjects:" GridPane.rowIndex="5" GridPane.columnIndex="0" />
        <FlowPane fx:id="subjects" hgap="5.0" vgap="5.0" GridPane.rowIndex="5" GridPane.columnIndex="1" />

        <Label text="Days:" GridPane.rowIndex="6" GridPane.columnIndex="0" />
        <FlowPane fx:id="days" hgap="5.0" vgap="5.0" GridPane.rowIndex="6" GridPane.columnIndex="1" />

        <Label text="Times:" GridPane.rowIndex="7" GridPane.columnIndex="0" />
        <FlowPane fx:id="times" hgap="5.0" vgap="5.0" GridPane.rowIndex="7" GridPane.columnIndex="1" />
    </GridPane>

    <!-- Close Button -->
    <HBox alignment="CENTER" spacing="10.0">
        <Button mnemonicParsing="false" onAction="#handleClose" text="Close" />
    </HBox>
</VBox>
