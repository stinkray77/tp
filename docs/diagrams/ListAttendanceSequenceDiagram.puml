@startuml ListAttendanceSequenceDiagram
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":ListAttendanceCommandParser" as Parser LOGIC_COLOR
participant "m:ListAttendanceCommand" as Command LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "model:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("listattendance 1 s/Math")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand(...)
activate AddressBookParser

create Parser
AddressBookParser -> Parser
activate Parser
Parser --> AddressBookParser
deactivate Parser

AddressBookParser -> Parser : parse(args)
activate Parser

create Command
Parser -> Command : index, subject (optional)
activate Command
Command --> Parser
deactivate Command

Parser --> AddressBookParser : m
deactivate Parser
Parser -[hidden]-> AddressBookParser
destroy Parser

AddressBookParser --> LogicManager : m
deactivate AddressBookParser

LogicManager -> Command : execute(model)
activate Command

Command -> Model : getFilteredPersonList()
activate Model
Model --> Command : lastShownList
deactivate Model

Command --> LogicManager : CommandResult
deactivate Command

[<--LogicManager
deactivate LogicManager
@enduml
